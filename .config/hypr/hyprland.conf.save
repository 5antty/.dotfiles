# This config is a STUB! This should never be generated.
# Use the default lua config from https://github.com/hyprwm/Hyprland/blob/main/example/hyprland.lua



$mainMod = SUPER
$terminal = kitty
$fileManager = dolphin
$menu = wofi

bind = $mainMod, Q, exec, $terminal
bind = $mainMod, C, killactive,
bind = $mainMod, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit
bind = $mainMod, E, exec, $fileManager
bind = $mainMod, V, togglefloating,
bind = $mainMod, R, exec, $menu

bind = $mainMod, O, exec, opera-gx
bind = $mainMod, D, exec, discord
bind = $mainMod, P, exec, spotify


# Cambiar el foco entre ventanas usando SUPER + Flechas
bind = SUPER, left, movefocus, l
bind = SUPER, right, movefocus, r
bind = SUPER, up, movefocus, u
bind = SUPER, down, movefocus, d

# Mover la ventana activa usando SUPER + SHIFT + Flechas
bind = SUPER SHIFT, left, movewindow, l
bind = SUPER SHIFT, right, movewindow, r
bind = SUPER SHIFT, up, movewindow, u
bind = SUPER SHIFT, down, movewindow, d

# Cambiar al workspace N (SUPER + Número)
bind = SUPER, 1, workspace, 1
bind = SUPER, 2, workspace, 2
bind = SUPER, 3, workspace, 3
bind = SUPER, 4, workspace, 4
# ... así hasta el 0 (que suele mapearse como el 10)
bind = SUPER, 0, workspace, 10

# Mover la ventana activa al workspace N (SUPER + SHIFT + Número)
bind = SUPER SHIFT, 1, movetoworkspace, 1
bind = SUPER SHIFT, 2, movetoworkspace, 2
bind = SUPER SHIFT, 3, movetoworkspace, 3
bind = SUPER SHIFT, 4, movetoworkspace, 4

#Maxmimizar una ventana
bind = SUPER, W, fullscreen, 1

workspace = 1, monitor:DP-2
workspace = 8, monitor:HDMI-A-1

monitor = DP-2, 1920x1080@300, 0x0, 1

exec-once = hyprpaper
exec-once = waybar


bind = $mainMod, L, exec,  hyprsunset -t 4000


decoration {
    rounding = 10            # Bordes redondeados en píxeles

    # Opacidad (Transparencias)
    active_opacity = 0.7     # Opacidad de la ventana enfocada (0.0 a 1.0)
    inactive_opacity = 0.8   # Opacidad de las ventanas en segundo plano

    # Desenfoque (Blur) estilo Cristal Esmerilado
    blur {
        enabled = true
        size = 10
        passes = 5
        new_optimizations = true
    }

    # Sombras
    shadow {
        enabled = true
        range = 4
        render_power = 3
        color = rgba(1a1a1aee)
    }
}

animations {
    enabled = true

    # Puedes definir curvas de velocidad (Beziers)
    bezier = myBezier, 0.05, 0.9, 0.1, 1.05

    # Aplicar las animaciones a las ventanas, difuminados, etc.
    animation = windows, 1, 7, myBezier
    animation = windowsOut, 1, 7, default, popin 80%
    animation = fade, 1, 7, default
}
